{
  "metadata": {
    "version": "4.16.9"
  },
  "events": [
    {
      "id": "block_change_packet",
      "name": "On Block Change Packet",
      "patterns": [
        "[on] block change packet"
      ],
      "event values": [
        "event-block",
        "event-block data",
        "event-location",
        "event-material",
        "event-player",
        "event-world"
      ],
      "cancellable": true
    },
    {
      "id": "chunk_data_packet",
      "name": "On Chunk Data Packet",
      "patterns": [
        "[on] chunk data packet"
      ],
      "cancellable": true
    },
    {
      "id": "player_action",
      "name": "On Player Action",
      "patterns": [
        "[on] player action packet"
      ],
      "event values": [
        "event-block",
        "event-integer",
        "event-location",
        "event-player",
        "event-text",
        "event-world"
      ],
      "cancellable": true
    },
    {
      "id": "sound_event",
      "name": "On Sound Event",
      "patterns": [
        "[on] sound packet"
      ],
      "event values": [
        "event-player",
        "event-world"
      ],
      "cancellable": true
    },
    {
      "id": "every_packet",
      "name": "On every packet",
      "patterns": [
        "[on] every packet"
      ],
      "event values": [
        "event-boolean (yes/no)",
        "event-object",
        "event-player",
        "event-world"
      ],
      "cancellable": true
    },
    {
      "id": "particle_send",
      "name": "On particle send",
      "patterns": [
        "[on] particle send"
      ],
      "event values": [
        "event-integer",
        "event-location",
        "event-number",
        "event-player",
        "event-types.bukkitparticle",
        "event-vector",
        "event-world"
      ],
      "cancellable": true
    }
  ],
  "effects": [
    {
      "id": "BaeFell",
      "name": "BaeFell",
      "patterns": [
        "baefell[-]ify [the] %entities% for %players%"
      ]
    },
    {
      "id": "EffBlockMarkerNew",
      "name": "Create Debug Marker New",
      "description": [
        "Create a colored debug marker at a location for players.",
        "Optionally you can add a text, alpha (transparency) and duration.",
        "Requires Minecraft 1.20.2+"
      ],
      "examples": [
        "create debug marker with color blue for player",
        "create debug marker with color rgb(200,100,100) for all players",
        "create debug marker with color red and with alpha 100 for all players",
        "create debug marker with color rgb(255,100,23) with alpha 50 for all players",
        "create debug marker with color green with alpha 25 with text \"I'M A MARKER!\" for player",
        "create debug marker with color yellow for all players for 10 seconds",
        "create debug marker with color rgb(100,100,100) for all players for 10 minutes"
      ],
      "since": [
        "INSERT VERSION"
      ],
      "patterns": [
        "create debug marker at %locations% with color %color% [[and ]with alpha %number%] [[and ]with text %string%] for %players% [for %timespan%]"
      ]
    },
    {
      "id": "EffAnimatePacket",
      "name": "EffAnimatePacket",
      "patterns": [
        "[send] animation [packet] [with] id %number% for entity [with id] %number% for %players%"
      ]
    },
    {
      "id": "EffAutoSpinAttack",
      "name": "EffAutoSpinAttack",
      "patterns": [
        "make %players% spin [attack] for %timespan%"
      ]
    },
    {
      "id": "EffBrand",
      "name": "EffBrand",
      "patterns": [
        "set server brand to %string% for %players%"
      ]
    },
    {
      "id": "EffChangeIP",
      "name": "EffChangeIP",
      "patterns": [
        "set ip of %player% to %string% with port %number%"
      ]
    },
    {
      "id": "EffChangeSkin",
      "name": "EffChangeSkin",
      "patterns": [
        "set skin of %players% to skin of %string% [with signature %string%]"
      ]
    },
    {
      "id": "EffChangeVision",
      "name": "EffChangeVision",
      "patterns": [
